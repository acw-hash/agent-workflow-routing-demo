APP_NAME=policy-chatbot
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

ALLOW_ANONYMOUS=true
CORS_ALLOWED_ORIGINS=*

ENTRA_TENANT_ID=<tenant-id>
ENTRA_CLIENT_ID=<client-id>
ENTRA_AUDIENCE=<audience-or-client-id>

FOUNDRY_PROJECT_ENDPOINT=https://<foundry-resource>.services.ai.azure.com/api/projects/<foundry-project>
FOUNDRY_PROJECT_NAME=<foundry-project-name>
FOUNDRY_RESOURCE_NAME=<foundry-resource-name>
FOUNDRY_WORKFLOW_NAME=<workflow-name>
FOUNDRY_WORKFLOW_ID=
FOUNDRY_WORKFLOW_ENDPOINT=
FOUNDRY_WORKFLOW_API_VERSION=2025-11-15-preview
FOUNDRY_WORKFLOW_BASE_ENDPOINT=
FOUNDRY_WORKFLOW_RUN_API_VERSION=
FOUNDRY_WORKFLOW_SCOPE=https://ml.azure.com/.default
FOUNDRY_SUBSCRIPTION_ID=
FOUNDRY_RESOURCE_GROUP=
FOUNDRY_WORKSPACE_NAME=
FOUNDRY_SCOPE=https://ai.azure.com/.default
FOUNDRY_API_KEY=
FOUNDRY_TIMEOUT_SECONDS=30

COSMOS_ENABLED=false
COSMOS_ENDPOINT=
COSMOS_DATABASE=policy-chatbot-db
COSMOS_SESSIONS_CONTAINER=chat-sessions
COSMOS_MESSAGES_CONTAINER=chat-messages
COSMOS_KEY=

APPINSIGHTS_CONNECTION_STRING=
